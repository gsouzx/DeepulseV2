PORT=3001

# Comma-separated list of origins allowed to connect (gates both the REST
# API CORS and the Socket.io realtime layer). No wildcard support — unset
# or empty fails CLOSED (every cross-origin request rejected), not open.
# In production (Railway), set this to the real deployed frontend
# domain(s), e.g.:
# ALLOWED_ORIGINS=https://deeppulse-three.vercel.app
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
