PORT=3001

# Comma-separated list of origins allowed to connect (gates both the REST
# API CORS and the Socket.io realtime layer). Leave unset or "*" to allow
# all origins (temporary, while the Vercel domain isn't final) — set it to
# your real Vercel domain(s) once known, e.g.:
# ALLOWED_ORIGINS=https://deeppulse.vercel.app
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
